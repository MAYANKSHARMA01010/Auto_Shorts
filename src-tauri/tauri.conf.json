{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AutoShorts",
  "version": "0.1.3",
  "identifier": "com.autoshorts.desktop",
  "build": {
    "beforeDevCommand": "npm run dev --prefix frontend",
    "devUrl": "http://127.0.0.1:3000",
    "beforeBuildCommand": "npm run build --prefix frontend",
    "frontendDist": "../frontend/out"
  },
  "app": {
    "windows": [
      {
        "title": "AutoShorts",
        "width": 1280,
        "height": 840,
        "minWidth": 1040,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
